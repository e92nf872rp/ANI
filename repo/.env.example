# ANI 开发环境变量模板
# 复制为 .env 并修改后，各服务自动加载
# 警告：.env 文件不得提交到版本控制（已加入 .gitignore）

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://ani:ani_dev_password@localhost:5432/ani?sslmode=disable
# 已有 PG 数据卷（非空卷 make deps）需补齐 Gateway 元数据表时：
# make db-upgrade-gateway-metadata
# 新空卷 make deps 已自动初始化，见 deploy/postgres/README.md

# ── 对象存储 ──────────────────────────────────────────────────────────────────
OBJECT_STORE_ENDPOINT=localhost:9000
OBJECT_STORE_ACCESS_KEY_ID=ani-admin
OBJECT_STORE_SECRET_ACCESS_KEY=ani_dev_password
OBJECT_STORE_SECURE=false
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_BUCKET_PREFIX=ani-dev

# ── 消息队列 ──────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── 缓存 ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:ani_dev_password@localhost:6379/0

# ── 向量数据库 ────────────────────────────────────────────────────────────────
MILVUS_ADDR=localhost:19530

# ── 认证 ──────────────────────────────────────────────────────────────────────
# JWT 签名密钥（生产环境使用 RSA 私钥文件）
AUTH_JWT_ISSUER=ani-dev
AUTH_JWT_PRIVATE_KEY_FILE=/root/ANI-work/repo/deploy/docker/config/ani-dev-jwt-private.pem
AUTH_JWT_PUBLIC_KEY_FILE=/root/ANI-work/repo/deploy/docker/config/ani-dev-jwt-public.pem

# OIDC / Dex（开发时可留空；启用 Dex profile 后 issuer 会自动推导 /auth、/token、/keys）
AUTH_OIDC_ISSUER_URL=http://127.0.0.1:5556/dex
AUTH_OIDC_CLIENT_ID=ani-console
AUTH_OIDC_CLIENT_SECRET=ani-console-secret
AUTH_OIDC_GROUP_ROLE_MAP_JSON='{"ani-admins":["tenant-admin"],"tenant-admin":["tenant-admin"]}'
# 如接入非 Dex-compatible IdP，可显式覆盖以下端点：
# AUTH_OIDC_AUTH_URL=http://127.0.0.1:5556/dex/auth
# AUTH_OIDC_TOKEN_URL=http://127.0.0.1:5556/dex/token
# AUTH_OIDC_JWKS_URL=http://127.0.0.1:5556/dex/keys

# ── ANI Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_ENV=development
LOG_LEVEL=debug

# ── Kubernetes REST provider（本地连集群，可选）────────────────────────────────
# 默认 local profile 不连集群。启用 kubernetes_rest / kubeovn_rest 等 provider 后：
# 1) 显式 env（生产首选）KUBERNETES_API_HOST + KUBERNETES_BEARER_TOKEN
# 2) 或自动读取 KUBECONFIG / ~/.kube/config（本地开发）
# 3) 或 Pod 内 in-cluster ServiceAccount（KUBERNETES_SERVICE_HOST 注入）
# KUBECONFIG=$HOME/.kube/config
# KUBERNETES_CONFIG_CONTEXT=my-context
# KUBERNETES_CONFIG_AUTO_LOAD=true
# KUBERNETES_API_HOST=http://127.0.0.1:8001
# KUBERNETES_BEARER_TOKEN=
# SECRET_PROVIDER_MODE=kubernetes_rest

# ── 实例 workload provider（Gateway /instances，可选）────────────────────────
# 默认 local：仅在 PG/内存模拟，不写集群。与 M1-INSTANCE-P bootstrap 语义一致。
# WORKLOAD_PROVIDER=kubernetes_rest
# WORKLOAD_PROVIDER_APPLY_ENABLED=true
# WORKLOAD_LIFECYCLE_PROVIDER=kubernetes_rest
# WORKLOAD_LIFECYCLE_APPLY_ENABLED=true
# WORKLOAD_OPS_PROVIDER=kubernetes_rest
# WORKLOAD_OPS_ENABLED=true
# GPU_INVENTORY_PROVIDER=kubernetes_rest
# 无 Kube-OVN/Multus 时 VM 联调临时 bypass（非产品默认；装好后应关掉）
# WORKLOAD_VM_POD_NETWORK=true

# ── 网络 provider（Gateway /networks/*，Sprint 13 S01 Kube-OVN）────────────────
# 默认 local profile：VPC/子网/路由等仅写 PG/内存，不 apply 到底层。
# 真实 Kube-OVN 需集群已装 Kube-OVN + 下列 env（与 sprint13-production-shaped-gateway-deployment.yaml 一致）：
# NETWORK_PROVIDER=kubeovn_rest
# NETWORK_PROVIDER_APPLY_ENABLED=true
# NETWORK_PROVIDER_USER_ID=ani-core-network-provider
# NETWORK_PROVIDER_PERMISSION_PROOF=rbac-scope:networks.write
# 契约门禁：make validate-kubeovn-network-live-gate
# 真实 lab（写操作 + cleanup）：python scripts/validate_kubeovn_network_live_gate.py --live --cleanup
# readiness：development-records/sprint13-netroute-kubeovn-readiness.md
# 实例 VM 默认走 Multus 三网（tenant-vpc/foundation-mesh/management）；需 Multus + Kube-OVN NAD。
# 在 NETWORK_PROVIDER 就绪且 Multus 可用前，勿关 WORKLOAD_VM_POD_NETWORK。

# ── RAG 引擎 ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
# HuggingFace 镜像站（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ── 模型仓库 ──────────────────────────────────────────────────────────────────
# ANI Gateway 内部地址（供 Init Container 使用）
ANI_GATEWAY_INTERNAL_URL=http://ani-gateway.ani-system.svc.cluster.local:8080
